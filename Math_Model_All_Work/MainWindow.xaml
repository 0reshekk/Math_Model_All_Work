<Window
    x:Class="Math_Model_All_Work.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Math_Model_All_Work"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Шаблон задач математического моделирования"
    Width="1120"
    Height="760"
    MinWidth="980"
    MinHeight="640"
    mc:Ignorable="d">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ===================== ЛЕВАЯ КОЛОНКА: НАСТРОЙКА ШАБЛОНА =====================  -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!--  ===== ОБЩИЙ БЛОК: ВЫБОР ТИПА ЗАДАЧИ =====  -->
                <Border
                    Padding="12"
                    Background="#F5F7FB"
                    BorderBrush="#D7DEEA"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Тип задачи" />
                        <ComboBox x:Name="TaskBox" SelectedIndex="0">
                            <ComboBoxItem>1. Система массового обслуживания</ComboBoxItem>
                            <ComboBoxItem>2. Транспортная задача: северо-западный угол</ComboBoxItem>
                            <ComboBoxItem>3. Транспортная задача: минимальный элемент</ComboBoxItem>
                            <ComboBoxItem>4. Симплекс-метод</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!--  ===== БЛОК ЗАДАЧИ: СМО =====  -->
                <Border
                    x:Name="SmoPanel"
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D7DEEA"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Параметры СМО" />
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Режим расчета" />
                        <ComboBox
                            x:Name="SmoModeBox"
                            Margin="0,0,0,12"
                            SelectedIndex="0">
                            <ComboBoxItem>1. Универсальный: ограниченная очередь (M/M/n/K)</ComboBoxItem>
                            <ComboBoxItem>2. Одноканальная с отказами (M/M/1/1)</ComboBoxItem>
                            <ComboBoxItem>3. Многоканальная с отказами (M/M/n/n)</ComboBoxItem>
                            <ComboBoxItem>4. Одноканальная с бесконечной очередью (M/M/1)</ComboBoxItem>
                            <ComboBoxItem>5. Многоканальная с бесконечной очередью (M/M/n)</ComboBoxItem>
                            <ComboBoxItem>6. Одноканальная с фиксированным временем обслуживания (M/D/1)</ComboBoxItem>
                            <ComboBoxItem>7. Ограниченное время ожидания</ComboBoxItem>
                        </ComboBox>

                        <UniformGrid
                            Margin="0,0,0,12"
                            Columns="2"
                            Rows="5">
                            <TextBlock VerticalAlignment="Center" Text="λ (интенсивность заявок):" />
                            <TextBox
                                x:Name="LambdaBox"
                                Margin="6,4"
                                Text="2" />

                            <TextBlock VerticalAlignment="Center" Text="μ (интенс. обслуживания):" />
                            <TextBox
                                x:Name="MuBox"
                                Margin="6,4"
                                Text="3" />

                            <TextBlock
                                x:Name="TserviceLabel"
                                VerticalAlignment="Center"
                                Text="t обслуживания (сек):" />
                            <TextBox
                                x:Name="TserviceBox"
                                Margin="6,4"
                                Text="0" />

                            <TextBlock
                                x:Name="NLabel"
                                VerticalAlignment="Center"
                                Text="n (каналов):" />
                            <TextBox
                                x:Name="NBox"
                                Margin="6,4"
                                Text="1" />

                            <TextBlock
                                x:Name="KLabel"
                                VerticalAlignment="Center"
                                Text="K (макс. размер системы):" />
                            <TextBox
                                x:Name="KBox"
                                Margin="6,4"
                                Text="2" />
                        </UniformGrid>

                        <TextBlock
                            x:Name="SmoHintText"
                            FontSize="12"
                            Foreground="#5B6474"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  ===== БЛОК ЗАДАЧИ: ТРАНСПОРТНАЯ =====  -->
                <Border
                    x:Name="TransportPanel"
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D7DEEA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Транспортная задача" />
                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Матрица стоимости" />
                        <DataGrid
                            x:Name="CostMatrix"
                            Height="180"
                            Margin="0,0,0,12"
                            AutoGenerateColumns="False"
                            Background="#EEF3FF"
                            CanUserAddRows="False"
                            HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Path=V1}" Header="B1" />
                                <DataGridTextColumn Binding="{Binding Path=V2}" Header="B2" />
                                <DataGridTextColumn Binding="{Binding Path=V3}" Header="B3" />
                                <DataGridTextColumn Binding="{Binding Path=V4}" Header="B4" />
                                <DataGridTextColumn Binding="{Binding Path=V5}" Header="B5" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Запасы (поставщики)" />
                        <TextBox
                            x:Name="SupplyInput"
                            Margin="0,0,0,12"
                            Text="30,40,20"
                            ToolTip="Введите числа через запятую" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Потребности (потребители)" />
                        <TextBox
                            x:Name="DemandInput"
                            Text="20,30,25,15,0"
                            ToolTip="Введите числа через запятую" />
                    </StackPanel>
                </Border>

                <!--  ===== БЛОК ЗАДАЧИ: СИМПЛЕКС =====  -->
                <Border
                    x:Name="SimplexPanel"
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="White"
                    BorderBrush="#D7DEEA"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,6"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Симплекс-метод" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Целевая функция" />
                        <TextBox
                            x:Name="ObjectiveInput"
                            Margin="0,0,0,12"
                            Text="3 5" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Матрица ограничений A" />
                        <TextBox
                            x:Name="MatrixInput"
                            Height="120"
                            Margin="0,0,0,12"
                            AcceptsReturn="True"
                            Text="1 0&#10;0 2&#10;3 2"
                            VerticalScrollBarVisibility="Auto" />

                        <TextBlock
                            Margin="0,0,0,6"
                            FontWeight="Bold"
                            Text="Правая часть b" />
                        <TextBox
                            x:Name="BInput"
                            Margin="0,0,0,12"
                            Text="4 12 18" />

                        <TextBlock
                            FontSize="12"
                            Foreground="#5B6474"
                            Text="Формат: max Z, ограничения только вида ≤, правая часть b должна быть неотрицательной."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  ===== ОБЩИЙ БЛОК: ДЕЙСТВИЯ С ШАБЛОНОМ =====  -->
                <Border
                    Margin="0,12,0,0"
                    Padding="12"
                    Background="#F5F7FB"
                    BorderBrush="#D7DEEA"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="16"
                            FontWeight="Bold"
                            Text="Общие действия" />
                        <WrapPanel ItemHeight="38" ItemWidth="185">
                            <Button
                                x:Name="CalcBtn"
                                Height="36"
                                Margin="0,0,8,8"
                                Click="CalcBtn_Click"
                                Content="Рассчитать" />
                            <Button
                                Height="36"
                                Margin="0,0,8,8"
                                Click="ImportExcel_Click"
                                Content="Импорт Excel" />
                            <Button
                                Height="36"
                                Margin="0,0,8,8"
                                Click="Export_Click"
                                Content="Экспорт" />
                            <Button
                                Height="36"
                                Margin="0,0,8,8"
                                Click="Clear_Click"
                                Content="Сбросить" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!--  ===================== ПРАВАЯ КОЛОНКА: РЕЗУЛЬТАТЫ =====================  -->
        <Border
            Grid.Column="2"
            Padding="12"
            Background="White"
            BorderBrush="#D7DEEA"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  ===== ОБЩИЙ БЛОК: РЕЗУЛЬТАТЫ =====  -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Text="Результаты" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="#4E5B70"
                        Text="Этот блок можно оставить общим даже после удаления лишних панелей конкретных задач."
                        TextWrapping="Wrap" />
                </StackPanel>

                <TextBox
                    x:Name="ResultText"
                    Grid.Row="1"
                    AcceptsReturn="True"
                    FontFamily="Consolas"
                    FontSize="14"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>
    </Grid>
</Window>
